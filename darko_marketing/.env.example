# ──────────────────────────────────────────────────────────────────────────────
# DARKO MARKETING AGENT — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM PROVIDER (required) ──────────────────────────────────────────────────
# Choose one: "google" (default), "anthropic", or "openai"
LLM_PROVIDER=google

# Google Gemini (default — free tier available)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-flash

# OR for Anthropic Claude:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OR for OpenAI:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# ── REDDIT (optional — live intel scraping) ──────────────────────────────────
# Get credentials at: https://www.reddit.com/prefs/apps
# Without these, the pipeline falls back to the expanded static scenario bank.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=darko-intel/1.0

# ── X / TWITTER (optional — thread auto-posting) ─────────────────────────────
# Get credentials at: https://developer.x.com/en/portal/dashboard
# Requires a project with Read+Write permissions and OAuth 1.0a user context.
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# ── GHOST CMS (optional — blog auto-publishing) ──────────────────────────────
# Get Admin API key from: Ghost Admin → Settings → Integrations → Add custom integration
# URL format: https://your-site.ghost.io  (no trailing slash)
GHOST_API_URL=https://your-site.ghost.io
GHOST_ADMIN_API_KEY=your_key_id:your_hex_secret
